models/*
!models/class_names.json
!models/.gitkeep

# ---- Training data (large; regenerate via training/download_quickdraw.py) ----
data/

# ---- Personal / private (never publish) ----
models/teacher_voice.json

# ---- Distributable archives ----
*.zip

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
.idea/
.vscode/
