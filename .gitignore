# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/

# ---- Virtual environments ----
.venv/
venv/
env/

# ---- Build / packaging artifacts ----
build/
dist/
*.manifest

# ---- Logs & runtime output ----
*.log
outputs/

